.venv
.env
.envrc

.vscode
*/build
private

# imagemanager/build/ holds hand-written controller source + Dockerfile (NOT generated
# build artifacts), so keep it tracked despite the */build rule above.
!imagemanager/build/
!imagemanager/build/**

# Python bytecode (e.g. from local test runs)
__pycache__/
*.pyc

# Catalog entries (manifest/docs/crds/settings) live only in the shared
# eda-catalog repo (github.com/kkayhan/eda-catalog) — this repo is source-only.
apps/
